<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_discount_display" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sale.report.discount</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!--
                Agregamos la opción en la sección "Cotizaciones y Pedidos"
                después del configurador de PDF para quotes, ya que también
                afecta la apariencia del PDF del presupuesto.
            -->
            <xpath expr="//setting[@id='sale_pdf_quote_builder']" position="after">
                <setting
                    id="sale_report_discount_display"
                    string="Mostrar descuento en el PDF del presupuesto"
                    help="Muestra el total original tachado, el total a pagar en negrita y el descuento aplicado en verde cuando el pedido tiene descuentos."
                    company_dependent="1"
                >
                    <field name="sale_report_show_discount"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
